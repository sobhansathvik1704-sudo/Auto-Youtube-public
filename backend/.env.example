APP_NAME=YouTube AI MVP
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api

SECRET_KEY=replace-this-with-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=youtube_ai
POSTGRES_USER=youtube_ai
POSTGRES_PASSWORD=youtube_ai

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

DATABASE_URL=postgresql+psycopg://youtube_ai:youtube_ai@db:5432/youtube_ai

CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

ARTIFACTS_DIR=/tmp/youtube_ai_artifacts
# Storage backend: "local" (default) or "s3"
STORAGE_BACKEND=local

# AWS S3 – required when STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=us-east-1

# "openai" for GPT-4o (paid), "gemini" for Google Gemini (free), or "local" for template-based fallback
LLM_PROVIDER=local
LLM_MODEL=local-fallback
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# Google Gemini – free AI script generation (15 req/min, 1500 req/day)
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

TTS_PROVIDER=local
# Voice name for Google Cloud TTS. Use Neural2 voices for best quality.
# Best voices for Indian English: en-IN-Neural2-D (female), en-IN-Neural2-B (male)
# Best voices for US English: en-US-Neural2-D (male), en-US-Neural2-E (female)
# Full list: https://cloud.google.com/text-to-speech/docs/voices
TTS_VOICE=en-IN-Neural2-D
# Speaking rate (0.25-4.0, 1.0 = normal, try 1.05 for slightly energetic narration)
TTS_SPEAKING_RATE=1.0
GOOGLE_APPLICATION_CREDENTIALS=

VIDEO_RENDER_FPS=30
SHORT_VIDEO_WIDTH=1080
SHORT_VIDEO_HEIGHT=1920
LONG_VIDEO_WIDTH=1920
LONG_VIDEO_HEIGHT=1080

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Pexels stock image backgrounds – optional, falls back to gradient if empty
# Register for a free API key at https://www.pexels.com/api/
PEXELS_API_KEY=
# Set to "huggingface" for AI cinematic images, "pexels" for stock photos, or "gradient" for solid backgrounds
IMAGE_PROVIDER=gradient

# HuggingFace Inference API – free AI image generation for cinematic scene backgrounds
# Get a free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=
# Working models (April 2026): black-forest-labs/FLUX.1-schnell, stabilityai/stable-diffusion-xl-base-1.0
# ByteDance/SDXL-Lightning, CompVis/stable-diffusion-v1-4
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HuggingFace Inference Provider ("hf-inference", "fal-ai", "replicate", "together")
HF_INFERENCE_PROVIDER=hf-inference

# YouTube Data API v3 – OAuth 2.0 credentials
# Download client_secrets.json from Google Cloud Console (OAuth 2.0 Client ID)
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
# Path where the OAuth token is cached after the first auth flow
YOUTUBE_TOKEN_FILE=youtube_token.json

# Avatar / Faceless Video (optional)
# Set AVATAR_PROVIDER=did to enable AI avatar video via D-ID Talks API
AVATAR_PROVIDER=static
DID_API_KEY=
DID_AVATAR_IMAGE_URL=https://create-images-results.d-id.com/DefaultPresenters/Noelle_f/image.jpeg
DID_VOICE_PROVIDER=microsoft
DID_VOICE_ID=en-US-JennyNeural
# Thumbnail generation provider: "pillow" (free, default) or "dalle" (requires OpenAI credits)
THUMBNAIL_PROVIDER=pillow
